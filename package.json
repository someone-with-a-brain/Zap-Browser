{
  "name": "browser",
  "version": "1.0.0",
  "description": "A lightweight, privacy-first Chromium-based browser built in C++20.",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.zap.browser",
    "productName": "Zap Browser",
    "copyright": "Copyright © 2026 Zap Team",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/someone-with-a-brain/Zap-Browser.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/someone-with-a-brain/Zap-Browser/issues"
  },
  "homepage": "https://github.com/someone-with-a-brain/Zap-Browser#readme",
  "dependencies": {
    "axios": "^1.15.0",
    "better-sqlite3": "^12.8.0",
    "electron": "^41.2.0"
  },
  "devDependencies": {
    "electron-builder": "24.13.3"
  }
}
